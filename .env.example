# === FAIRMED API KEYS ===
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# REQUIRED: NVIDIA NIM API Key
# Get it: https://build.nvidia.com → Sign up → API Key
# Free tier: 1000 credits
NVIDIA_API_KEYS=nvapi-your-key-here,nvapi-your-key-here

# REQUIRED: Supabase (database for Medicare rates, billing rules, analysis results)
# Get it: https://supabase.com → New Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIs...your-anon-key...

# OPTIONAL: No key needed for ICD10API (free, no auth)
# OPTIONAL: No key needed for DuckDuckGo search (free, no auth)
# OPTIONAL: No key needed for Medicare rates (local JSON)
