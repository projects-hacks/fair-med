# === FAIRMED API KEYS ===
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# REQUIRED: NVIDIA NIM API Key
# Get it: https://build.nvidia.com → Sign up → API Key
# Free tier: 1000 credits
NVIDIA_API_KEYS=nvapi-your-key-here,nvapi-your-key-here

# REQUIRED: Supabase (database for Medicare rates, billing rules, analysis results)
# Get it: https://supabase.com → New Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIs...your-anon-key...

# OPTIONAL: Override RPM limit if your account has higher limits
# Check your limit at build.nvidia.com (profile → API Rate Limit)
# Default: 40 (free tier). Higher limits skip rate-limit sleeps entirely.
# NIM_RPM=40

# No key needed for ICD10API (free, no auth)
# No key needed for DuckDuckGo search (free, no auth)
